<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PowerHunter.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:models="clr-namespace:PowerHunter.Models"
             xmlns:converters="clr-namespace:PowerHunter.Converters"
             x:Class="PowerHunter.Views.StatsPage"
             x:Name="StatsPageRoot"
             x:DataType="vm:StatsViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24,40,24,20" Spacing="0">

            <!-- Page Header -->
            <VerticalStackLayout Margin="0,0,0,24" Spacing="4">
                <Label Text="Stats"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}" />
                <Label Text="Battery overview, trend, and category insights"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
            </VerticalStackLayout>

            <!-- Permission Banner -->
            <Border Margin="0,0,0,16"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Amber50}, Dark={StaticResource DarkWarnBg}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    IsVisible="{Binding ShowPermissionBanner}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="&#x26A0;&#xFE0F;"
                           FontSize="20"
                           VerticalOptions="Center" />

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Usage Access Required"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Amber800}, Dark={StaticResource Amber500}}" />
                        <Label Text="Grant permission to view system-reported app usage stats and unlock top consumer telemetry."
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light={StaticResource Amber800}, Dark={StaticResource Amber500}}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="Grant"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="White"
                            BackgroundColor="{StaticResource Amber500}"
                            CornerRadius="12"
                            Padding="12,6"
                            Command="{Binding RequestUsageStatsPermissionCommand}"
                            Shadow="{x:Null}" />
                </Grid>
            </Border>

            <!-- Hero Card -->
            <Border Padding="24"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCard}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Margin="0,0,0,24">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Today's Usage"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Slate700}, Dark={StaticResource Gray200}}" />

                        <Label Text="{Binding BatteryPercent, StringFormat='{0:F1}%'}"
                               FontSize="42"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Emerald500}" />

                        <HorizontalStackLayout Spacing="10">
                            <Border Padding="12,6"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Emerald50}, Dark={StaticResource DarkInfoBg}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="{Binding SessionCount, StringFormat='🔋 {0} sessions'}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Emerald600}, Dark=White}" />
                            </Border>

                            <Border Padding="12,6"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="{Binding SelectedScopeText, StringFormat='Scope: {0}'}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Slate600}, Dark={StaticResource Gray300}}" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Battery Icon -->
                    <Border Grid.Column="1"
                            WidthRequest="64"
                            HeightRequest="96"
                            Padding="10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Emerald50}, Dark={StaticResource DarkInfoBg}}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20"
                            VerticalOptions="Center">
                        <Grid WidthRequest="36" HeightRequest="62"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <BoxView WidthRequest="12"
                                     HeightRequest="5"
                                     CornerRadius="2"
                                     Color="{AppThemeBinding Light={StaticResource Emerald500}, Dark={StaticResource Emerald500}}"
                                     VerticalOptions="Start"
                                     HorizontalOptions="Center" />
                            <Border Margin="0,7,0,0"
                                    BackgroundColor="Transparent"
                                    Stroke="{AppThemeBinding Light={StaticResource Emerald500}, Dark={StaticResource Emerald500}}"
                                    StrokeThickness="2.5"
                                    StrokeShape="RoundRectangle 8" />
                            <BoxView Margin="5,14,5,5"
                                     VerticalOptions="End"
                                     HeightRequest="30"
                                     CornerRadius="4"
                                     Color="{AppThemeBinding Light={StaticResource Emerald500}, Dark={StaticResource Emerald500}}"
                                     Opacity="0.25" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Day / Week Toggle -->
            <Border Margin="0,0,0,24"
                    Padding="4"
                    HorizontalOptions="Center"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="*,*" WidthRequest="220">
                    <Button Grid.Column="0"
                            Text="Day"
                            FontSize="14"
                            FontAttributes="Bold"
                            Padding="0,10"
                            CornerRadius="14"
                            Command="{Binding SetTimeframeCommand}"
                            CommandParameter="day"
                            Shadow="{x:Null}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsDayTimeframe}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource DarkCard}}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsDayTimeframe}"
                                         Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Grid.Column="1"
                            Text="Week"
                            FontSize="14"
                            FontAttributes="Bold"
                            Padding="0,10"
                            CornerRadius="14"
                            Command="{Binding SetTimeframeCommand}"
                            CommandParameter="week"
                            Shadow="{x:Null}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsDayTimeframe}"
                                         Value="False">
                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource DarkCard}}" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsDayTimeframe}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>

            <!-- Select App -->
            <VerticalStackLayout Margin="0,0,0,24" Spacing="12">
                <Label Text="Select App"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark=White}" />

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="16">

                        <!-- All Apps -->
                        <VerticalStackLayout Spacing="6" WidthRequest="60">
                            <Border WidthRequest="52"
                                    HeightRequest="52"
                                    Padding="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Emerald50}, Dark={StaticResource DarkInfoBg}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource DarkBorder}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ResetAppSelectionCommand}" />
                                </Border.GestureRecognizers>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding HasSelectedApp}"
                                                 Value="False">
                                        <Setter Property="Stroke" Value="{StaticResource Emerald500}" />
                                        <Setter Property="StrokeThickness" Value="2.5" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Label Text="⚡"
                                       FontSize="24"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>

                            <Label Text="All Apps"
                                   FontSize="10"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray50}}" />
                        </VerticalStackLayout>

                        <!-- Dynamic Apps -->
                        <HorizontalStackLayout Spacing="16"
                                               BindableLayout.ItemsSource="{Binding Apps}"
                                               IsVisible="{Binding HasApps}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:TrackedAppInfo">
                                    <VerticalStackLayout Spacing="6" WidthRequest="60">
                                        <Border WidthRequest="52"
                                                HeightRequest="52"
                                                Padding="0"
                                                BackgroundColor="{Binding BadgeColor}"
                                                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource DarkBorder}}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 16">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference StatsPageRoot}, Path=BindingContext.SelectAppCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>

                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}" />
                                                    <Setter Property="StrokeThickness" Value="2.5" />
                                                </DataTrigger>
                                            </Border.Triggers>

                                            <Grid>
                                                <Image Source="{Binding IconSource}"
                                                       IsVisible="{Binding HasIconSource}"
                                                       Aspect="AspectFit"
                                                       Margin="8" />
                                                <Label Text="{Binding FallbackGlyph}"
                                                       IsVisible="{Binding HasIconSource, Converter={StaticResource InverseBool}}"
                                                       FontSize="22"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="{Binding IconColor}" />
                                            </Grid>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontSize="10"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray50}}" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>

                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- Battery Trend -->
            <Border Padding="24"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCard}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Margin="0,0,0,24">
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Battery Trend"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark=White}" />
                            <Label Text="{Binding TrendDescriptionText}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="1"
                                Padding="12,6"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Start">
                            <Label Text="{Binding TelemetryBadgeText}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Slate600}, Dark={StaticResource Gray300}}" />
                        </Border>
                    </Grid>

                    <lvc:CartesianChart Series="{Binding TrendSeries}"
                                        XAxes="{Binding TrendXAxes}"
                                        YAxes="{Binding TrendYAxes}"
                                        HeightRequest="240"
                                        ZoomMode="None"
                                        TooltipPosition="Top" />
                </VerticalStackLayout>
            </Border>

            <!-- Category Distribution -->
            <Border Padding="24"
                    BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource DarkCard}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource DarkBorder}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Category Distribution"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark=White}" />
                        <Label Text="{Binding SelectedScopeText, StringFormat='Scope: {0}'}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    </VerticalStackLayout>

                    <lvc:PieChart Series="{Binding CategorySeries}"
                                  HeightRequest="240"
                                  InitialRotation="-90"
                                  TooltipPosition="Hidden" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Categories}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoryUsage">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <BoxView Grid.Column="0"
                                             WidthRequest="10"
                                             HeightRequest="10"
                                             CornerRadius="5"
                                             VerticalOptions="Center"
                                             Color="{Binding HexColor}" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray50}}" />

                                    <Label Grid.Column="2"
                                           Text="{Binding Percentage, StringFormat='{0:0.#}%'}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray50}}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border Padding="14"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource DarkBorder}}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18">
                        <Grid ColumnDefinitions="3,*" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     WidthRequest="3"
                                     VerticalOptions="Fill"
                                     Color="{StaticResource Emerald500}" />

                            <Label Grid.Column="1"
                                   Text="{Binding CategoryInsightText}"
                                   FontSize="12"
                                   FontAttributes="Italic"
                                   LineBreakMode="WordWrap"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
